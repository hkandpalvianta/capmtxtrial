{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./gen/srv",
    "rootDir": ".",
    "resolveJsonModule": true,
    "paths": {
      "@sap/cds": ["./node_modules/@cap-js/cds-types"]
    }
  },
  "include": ["srv/**/*", "db/**/*", "app/**/*"],
  "exclude": ["node_modules", "gen", "app/*/dist", "app/*/webapp"]
}
