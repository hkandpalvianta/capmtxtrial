{
  "name": "capmtxtrial",
  "version": "1.0.0",
  "description": "Trial-compatible Multi-tenant SAP CAP Task Manager",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "app/*"
  ],
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/cds-mtxs": "^3",
    "@sap/xssec": "^4",
    "express": "^4",
    "uuid": "^11"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/jest": "^29",
    "@types/node": "^20",
    "concurrently": "^8",
    "jest": "^29",
    "mbt": "^1.2",
    "prettier": "^3",
    "ts-jest": "^29",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "dev": "cds watch",
    "dev:sidecar": "cd mtx/sidecar && cds watch --port 4005",
    "dev:all": "npx concurrently \"npm run dev:sidecar\" \"npm run dev\"",
    "start": "cds-serve",
    "build": "mbt build",
    "build:ts": "node --max-old-space-size=4096 node_modules/.bin/tsc --build",
    "build:ui5": "npm run build --workspaces --if-present",
    "build:all": "npm run build:ts && npm run build:ui5",
    "test": "jest",
    "deploy": "cf deploy mta_archives/capmtxtrial_1.0.0.mtar -f",
    "undeploy": "cf undeploy capmtxtrial --delete-services --delete-service-keys"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/unit/**/*.test.ts",
      "**/test/integration/**/*.test.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/gen/"
    ],
    "verbose": true,
    "testTimeout": 30000,
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "useESM": false }]
    }
  },
  "cds": {
    "requires": {
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": ["Admin", "Editor", "Viewer"]
            },
            "bob": {
              "password": "bob",
              "roles": ["Editor", "Viewer"]
            },
            "carol": {
              "password": "carol",
              "roles": ["Viewer"]
            }
          }
        }
      },
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": { "url": "db.sqlite" }
        },
        "[production]": {
          "kind": "hana",
          "deploy-format": "hdbtable"
        }
      },
      "[production]": {
        "multitenancy": { "t0": true },
        "toggles": true,
        "extensibility": false,
        "cds.xt.SaasProvisioningService": {
          "kind": "rest",
          "credentials": {
            "destination": "mtx-sidecar",
            "path": "/-/cds/saas-provisioning"
          }
        },
        "cds.xt.DeploymentService": {
          "kind": "rest",
          "credentials": {
            "destination": "mtx-sidecar",
            "path": "/-/cds/deployment"
          }
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "log": {
      "levels": {
        "cds": "info",
        "db": "info"
      }
    },
    "i18n": {
      "default_language": "en",
      "folders": ["_i18n", "i18n"]
    }
  }
}
